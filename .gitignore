
.env
# Ignore all data contents except DVC pointer files and .gitignore
data/*
!data/**/*.dvc
!data/**/.gitignore
!data/realwaste-main/RealWaste.dvc

# DVC Google Drive credentials
gdrive-creds.json

# Python cache/build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.pytest_cache/

# Virtual environments
.venv/
venv/

# MLflow local tracking files
mlflow.db
mlruns/

# Local run artifacts
model_info.txt

# OS/editor noise
.DS_Store
Thumbs.db